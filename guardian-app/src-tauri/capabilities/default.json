{
  "identifier": "default",
  "description": "Default capabilities",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "http://127.0.0.1:7647/**"
        },
        {
          "url": "http://127.0.0.1:7648/**"
        }
      ]
    }
  ]
}