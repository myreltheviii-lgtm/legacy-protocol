{
  "identifier": "default",
  "description": "Default capabilities",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "http:default",
    "http:allow-fetch",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://127.0.0.1:*/*"
        },
        {
          "url": "http://localhost:*/*"
        }
      ]
    }
  ]
}