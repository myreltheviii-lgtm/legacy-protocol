{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "baseUrl": "."
  },
  "include": ["tests/**/*", "sdk/src/**/*", "watcher/src/**/*", "relayer/src/**/*", "cloak-integration/src/**/*"]
}
