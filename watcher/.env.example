# watcher/.env.example
#
# Copy this file to .env and fill in real values before starting the watcher.
# Never commit .env to version control — it contains secret keys.
#
# In production, inject these via your secrets manager (Doppler, AWS Secrets
# Manager, Fly.io secrets) rather than a .env file on disk.

# ── Required ──────────────────────────────────────────────────────────────────

# Your private Solana RPC HTTP endpoint.
# The public endpoint (api.mainnet-beta.solana.com) will rate-limit the watcher.
SOLANA_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Your private Solana RPC WebSocket endpoint (same provider as above).
SOLANA_RPC_WS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# The deployed program ID from `anchor deploy`.
LEGACY_VAULT_PROGRAM_ID=LGCYvau1tXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Yellowstone Geyser gRPC endpoint URL.
# Obtain from your Geyser provider (Helius, Triton, Shyft, etc.).
# Format: https://<host>:<port>
GEYSER_GRPC_ENDPOINT=https://mainnet.helius-rpc.com:443

# Geyser authentication token (x-token header).
# Leave empty if your endpoint does not require authentication.
GEYSER_X_TOKEN=

# ── Signing pool (guardian keypairs for anomaly_flag transactions) ────────────
# Comma-separated base58-encoded secret keys.
# These keypairs have NO authority over vault funds.
# Fund each with ~0.1 SOL to cover transaction fees.
GUARDIAN_SECRET_KEYS=5Kg8...base58key1...,4Jm2...base58key2...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# How often the slot-based heartbeat checks whether to run a poll cycle.
# A poll cycle fires when (currentSlot - lastHeartbeatSlot) >= HEARTBEAT_SLOTS.
# Adaptive: Orange zone uses HEARTBEAT_SLOTS/3, Red zone uses HEARTBEAT_SLOTS/10.
# Default: 300 (~2 minutes at 2 slots/second)
HEARTBEAT_SLOTS=300

# How often to poll Solana for all vault states (milliseconds).
# This is the fallback polling interval used before the Geyser stream connects.
# Default: 30000 (30 seconds)
POLL_INTERVAL_MS=30000

# Maximum parallel vault reconciliations per poll cycle.
# Default: 20
POLL_CONCURRENCY=20

# SQLite database file path.
# Default: ./watcher.db
DB_PATH=./watcher.db

# Days of poll history to retain before pruning.
# Default: 30
DB_RETENTION_DAYS=30

# Base URL of the deployed app (used to build beneficiary claim Blink URLs).
# Default: http://localhost:3000
APP_BASE_URL=https://app.legacyprotocol.xyz

# How often the maintenance job runs (milliseconds).
# Default: 3600000 (1 hour)
MAINTENANCE_INTERVAL_MS=3600000

# Internal HTTP server port (health, /vaults, and /metrics endpoints).
# Default: 3001
INTERNAL_PORT=3001

# Log level: trace | debug | info | warn | error | fatal
# Default: info
LOG_LEVEL=info

# Set to "production" to disable pino-pretty and emit raw JSON logs.
NODE_ENV=development

