# relayer/.env.example
#
# Copy to .env and fill in values before starting the relayer.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

SOLANA_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_WS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
LEGACY_VAULT_PROGRAM_ID=LGCYvau1tXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Base58-encoded secret key for the relayer keypair.
# This keypair only pays transaction fees. Fund with ~1 SOL.
# Has ZERO authority over vault funds.
RELAYER_SECRET_KEY=5Kg8...base58...

# ── Optional ─────────────────────────────────────────────────────────────────

# "same-process" or "separate-process"
# Default: same-process
RELAYER_MODE=same-process

# Watcher base URL (separate-process mode only).
# Default: http://localhost:3001
WATCHER_URL=http://localhost:3001

# How often to poll the watcher in separate-process mode (ms).
# Default: 10000
RELAYER_POLL_MS=10000

# Port for the relayer health endpoint.
# Default: 3002
RELAYER_HEALTH_PORT=3002

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

NODE_ENV=development
