    "pino":              "^9.2.0",
    "pino-pretty":       "^11.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "ts-node":     "^10.9.2",
    "typescript":  "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
